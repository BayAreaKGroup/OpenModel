FROM lmsysorg/sglang:latest-runtime

ENV PYTHONUNBUFFERED=1
ENV FLASHINFER_USE_CUDA_NORM=1

RUN python3 -m pip install --no-cache-dir distro

ENV SGLANG_MODEL=Qwen/Qwen2.5-3B-Instruct
ENV SGLANG_HOST=0.0.0.0
ENV SGLANG_PORT=30000
ENV SGLANG_TP=1

WORKDIR /app

EXPOSE 30000

CMD ["sh", "-lc", "python3 -m sglang.launch_server \
  --model-path ${SGLANG_MODEL} \
  --host ${SGLANG_HOST} \
  --port ${SGLANG_PORT} \
  --tp ${SGLANG_TP}"]
